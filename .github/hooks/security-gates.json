{
  "version": 1,
  "hooks": [
    {
      "event": "postToolUse",
      "tools": ["edit"],
      "command": {
        "bash": "node .github/hooks/scripts/protect-env.js",
        "timeoutSec": 10
      }
    },
    {
      "event": "postToolUse",
      "tools": ["edit"],
      "command": {
        "bash": "node .github/hooks/scripts/detect-secrets.js",
        "timeoutSec": 10
      }
    },
    {
      "event": "postToolUse",
      "tools": ["edit"],
      "command": {
        "bash": "node .github/hooks/scripts/scope-directory.js",
        "timeoutSec": 10
      }
    }
  ]
}
