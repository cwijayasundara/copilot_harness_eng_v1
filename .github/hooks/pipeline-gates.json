{
  "version": 1,
  "hooks": [
    {
      "event": "postToolUse",
      "tools": ["execute"],
      "command": {
        "bash": "node .github/hooks/scripts/pre-commit-gate.js",
        "timeoutSec": 60
      }
    },
    {
      "event": "postToolUse",
      "tools": ["execute"],
      "command": {
        "bash": "node .github/hooks/scripts/sprint-contract-gate.js",
        "timeoutSec": 10
      }
    },
    {
      "event": "sessionEnd",
      "command": {
        "bash": "node .github/hooks/scripts/task-completed.js",
        "timeoutSec": 10
      }
    }
  ]
}
