{
  "version": 1,
  "hooks": [
    {
      "event": "postToolUse",
      "tools": ["edit"],
      "command": {
        "bash": "node .github/hooks/scripts/lint-on-save.js",
        "timeoutSec": 30
      }
    },
    {
      "event": "postToolUse",
      "tools": ["edit"],
      "command": {
        "bash": "node .github/hooks/scripts/typecheck.js",
        "timeoutSec": 30
      }
    },
    {
      "event": "postToolUse",
      "tools": ["edit"],
      "command": {
        "bash": "node .github/hooks/scripts/check-architecture.js",
        "timeoutSec": 10
      }
    },
    {
      "event": "postToolUse",
      "tools": ["edit"],
      "command": {
        "bash": "node .github/hooks/scripts/check-function-length.js",
        "timeoutSec": 5
      }
    },
    {
      "event": "postToolUse",
      "tools": ["edit"],
      "command": {
        "bash": "node .github/hooks/scripts/check-file-length.js",
        "timeoutSec": 5
      }
    }
  ]
}
